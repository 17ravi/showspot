# ShowSpot Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
REACT_APP_API_URL=http://localhost:3000
REACT_APP_API_TIMEOUT=10000

# Google Maps API
# Get your API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Environment
NODE_ENV=development

# App Configuration
REACT_APP_APP_NAME=ShowSpot
REACT_APP_VERSION=0.0.1

# Debug Options (set to true during development)
REACT_APP_DEBUG=true
REACT_APP_VERBOSE_LOGGING=false

# Feature Flags
REACT_APP_ENABLE_LOCATION=true
REACT_APP_ENABLE_CAMERA=true
REACT_APP_ENABLE_SOCIAL_FEATURES=true

# Analytics (optional)
# REACT_APP_ANALYTICS_TOKEN=your_token_here
# REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# Push Notifications (optional)
# REACT_APP_FCM_SENDER_ID=your_fcm_sender_id_here
# REACT_APP_APNS_KEY_ID=your_apns_key_id_here

# Feature Configuration
REACT_APP_MAX_PHOTO_SIZE_MB=10
REACT_APP_MAX_PHOTOS_PER_UPLOAD=5
REACT_APP_LOCATION_UPDATE_INTERVAL=10000

# Database (if needed)
# REACT_APP_DATABASE_URL=your_database_url_here

# Authentication (if needed)
# REACT_APP_AUTH0_DOMAIN=your_auth0_domain_here
# REACT_APP_AUTH0_CLIENT_ID=your_auth0_client_id_here

# Cache Configuration
REACT_APP_CACHE_PHOTOS=true
REACT_APP_CACHE_DURATION_MINUTES=60

# Server Configuration
REACT_APP_SERVER_PORT=3000
REACT_APP_SERVER_HOST=localhost
